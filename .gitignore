!hypr/**

!waybar/
!waybar/**

!swaync/
!swaync/**

!kitty/
!kitty/**

!eww/
!eww/**

!waypaper/
!waypaper/**

!cava/
!cava/**

!wlogout/
!wlogout/**

!wofi/
!wofi/**

!fastfetch/
!fastfetch/**

!gtk-3.0/
!gtk-3.0/**

!gtk-4.0/
!gtk-4.0/**

!xsettingsd/
!xsettingsd/**

!zathura/
!zathura/**

# MPD (track config only, ignore state/db/logs)
!mpd/
!mpd/mpd.conf
mpd/database
mpd/log
mpd/state
mpd/sticker.sql