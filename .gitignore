# Ignore everything by default
*

# Keep .gitignore itself
!.gitignore
!README.md

# Whitelist custom ricing config directories
!hypr/
!hypr/**

!waybar/
!waybar/**

!swaync/
!swaync/**

!kitty/
!kitty/**

!eww/
!eww/**

!waypaper/
!waypaper/**

!cava/
!cava/**

!wlogout/
!wlogout/**

!wofi/
!wofi/**

!fastfetch/
!fastfetch/**

!gtk-3.0/
!gtk-3.0/**

!gtk-4.0/
!gtk-4.0/**

!xsettingsd/
!xsettingsd/**

!zathura/
!zathura/**

!pics/
!pics/**

# MPD (track config only, ignore state/db/logs)
!mpd/
!mpd/mpd.conf
mpd/database
mpd/log
mpd/state
mpd/sticker.sql

# PipeWire / WirePlumber audio config overrides
!pipewire/
!pipewire/**

!wireplumber/
!wireplumber/**

# Systemd custom user units
!systemd/
!systemd/user/
!systemd/user/lightning-faud.service

# Lightning Fan custom utility
!lightning-fan/
!lightning-fan/**